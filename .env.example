# Database connection (required)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/open_horizons"

# Strategy preset - controls which node type hierarchy is active
# Available presets: "open-horizons" (Mission > Aim > Initiative > Task)
#                    "agentic-flow"  (Mission > Strategic Bet > Capability > Tactical Plan > Outcome)
STRATEGY_PRESET=open-horizons

# LLM config (optional, server-side only)
# Used by /api/mcp and future AI features
OPENAI_API_KEY=""
