# Database connection (required)
DATABASE_URL="postgres://postgres:postgres@localhost:5432/open_horizons"

# Node type preset (optional)
# Set to a built-in preset name or a key from NODE_TYPES_FILE
# STRATEGY_PRESET="agentic-flow"

# Path to a JSON file of custom node type presets (optional)
# NODE_TYPES_FILE="/app/config/node-types.json"

# LLM config (optional, server-side only)
# Required for markdown import feature
OPENAI_API_KEY=""
