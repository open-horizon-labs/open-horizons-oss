# Public Supabase config (required)
NEXT_PUBLIC_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY="YOUR_ANON_KEY"

# App base URL (used for invitation links, etc.)
# Local dev: http://localhost:3001
# Production: https://app.openhorizons.me
NEXT_PUBLIC_APP_URL="http://localhost:3001"

# Auth redirect URL (environment-specific)
# Local dev: http://localhost:3001/auth/callback
# Production: https://app.openhorizons.me/auth/callback
NEXT_PUBLIC_AUTH_REDIRECT_URL="http://localhost:3001/auth/callback"

# Service role key needed for invitation system
SUPABASE_SECRET_KEY="YOUR_SERVICE_ROLE_KEY"

# ES256 signing key for API key authentication (JWK format)
# Generate with: npx supabase gen signing-key --algorithm ES256
# Then import to Supabase dashboard: Project Settings > Auth > Signing Keys
SUPABASE_JWT_SIGNING_KEY='{"kty":"EC","kid":"YOUR_KEY_ID","use":"sig","key_ops":["sign","verify"],"alg":"ES256","ext":true,"d":"YOUR_PRIVATE_KEY","crv":"P-256","x":"YOUR_X","y":"YOUR_Y"}'

# LLM config (server-side only)
# Do not expose to client; used by /api/llm routes
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-5-nano"
# Controls reasoning tokens: minimal | low | medium | high
OPENAI_REASONING_EFFORT="minimal"

# Pipedream integration config (server-side only)
# Used for OAuth and workflow management via Pipedream Connect
PIPEDREAM_CLIENT_ID=""
PIPEDREAM_CLIENT_SECRET=""
# Pipedream Credentials
PIPEDREAM_ENVIRONMENT=development
PIPEDREAM_PROJECT_ID=proj_Bgsl5Xz

# Public Pipedream config (client-side)
# Used for Pipedream Connect OAuth flows
NEXT_PUBLIC_PIPEDREAM_CLIENT_ID=""

# Authentication Secret for MCP Chat App (added by Pipedream, not sure if it's needed)
AUTH_SECRET=""

# Strategy preset - controls which node type hierarchy is active
# Available presets: "open-horizons" (Mission > Aim > Initiative > Task)
#                    "agentic-flow"  (Mission > Strategic Bet > Capability > Tactical Plan > Outcome)
STRATEGY_PRESET=open-horizons
